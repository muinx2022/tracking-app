# Copy to .env and adjust. For local dev without Docker, leave USE_SQLITE=1.

# SECRET_KEY=change-me
# DEBUG=True
# ALLOWED_HOSTS=tracking.trekky.net,localhost,127.0.0.1

# Local dev server port (default 8777 — avoids 8000/8080/8100). Used by run_dev.ps1 hints.
# DJANGO_DEV_PORT=8777

# PostgreSQL (used by Docker / VPS deploy)
# DB_NAME=tracking
# DB_USER=tracking
# DB_PASSWORD=tracking
# DB_HOST=db
# DB_PORT=5432

# Use SQLite for quick local runs (no Postgres required)
USE_SQLITE=1
